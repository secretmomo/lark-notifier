{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "lib",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowImportingTsExtensions": false,
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/index.ts"],
  "exclude": ["**/*.test.ts"]
}
